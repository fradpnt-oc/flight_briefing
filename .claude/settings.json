{
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash(docker *)",
      "Bash(docker compose *)",
      "Bash(docker-compose *)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(alembic *)",
      "Bash(uvicorn *)",
      "Bash(nginx *)",
      "Bash(kubectl *)",
      "Bash(helm *)",
      "Bash(pwsh *)",
      "Bash(powershell *)",
      "Bash(sqlite3 *)",
      "Write(**/*.py)",
      "Write(**/*.ts)",
      "Write(**/*.tsx)",
      "Write(**/*.js)",
      "Write(**/*.jsx)",
      "Write(**/*.vue)",
      "Write(**/*.ps1)",
      "Write(**/*.md)",
      "Write(**/*.yml)",
      "Write(**/*.yaml)",
      "Write(**/*.json)",
      "Write(**/*.sql)",
      "Write(**/*.db)",
      "Write(**/*.sqlite)",
      "Write(**/*.sqlite3)",
      "Write(**/*.env.example)",
      "Write(**/nginx/**)",
      "Write(**/Dockerfile)",
      "Write(**/docker-compose*.yml)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(kubectl delete namespace *)",
      "Bash(kubectl delete cluster *)",
      "Bash(docker system prune -a *)",
      "Bash(sqlite3 * .drop *)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/.env.production)"
    ]
  }
}
